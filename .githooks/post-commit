#!/usr/bin/env bash
set -euo pipefail

# Skip auto deploy when needed
if [ "${SKIP_NETLIFY_DEPLOY:-}" = "1" ]; then
  exit 0
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" != "main" ]; then
  exit 0
fi

# Deploy the current workspace to Netlify production.
# Prefer local binary to avoid fetching from npm on every commit.
if [ -x "./node_modules/.bin/netlify" ]; then
  deploy_cmd=(./node_modules/.bin/netlify deploy --prod --dir .)
else
  deploy_cmd=(npx --yes netlify-cli deploy --prod --dir .)
fi

if ! "${deploy_cmd[@]}" >/tmp/gyosei_netlify_post_commit.log 2>&1; then
  echo "[post-commit] Netlify deploy failed: /tmp/gyosei_netlify_post_commit.log" >&2
fi
